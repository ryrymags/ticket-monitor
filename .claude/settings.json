{
  "permissions": {
    "allow": [
      "Bash(python3 -m pytest:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check_ci.sh"
          }
        ]
      }
    ]
  }
}
