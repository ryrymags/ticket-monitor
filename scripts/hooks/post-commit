#!/bin/bash
# Post-commit hook — regenerates CHANGELOG.md and README 'Recent Changes',
# then folds the update into the just-made commit via --amend.
#
# Install: run  scripts/install_hooks.sh  (or re-run installers/setup_mac.command)

# Guard against re-entrancy: amend would re-trigger this hook without the guard
LOCK=".git/.changelog_lock"
if [ -f "$LOCK" ]; then
    exit 0
fi
touch "$LOCK"
trap 'rm -f "$LOCK"' EXIT

SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$SCRIPT_DIR" || exit 0

# Regenerate changelog files. --pending-latest-hash: this runs BEFORE the amend
# below, so HEAD's hash is about to change — the flag tells gen_changelog.py to
# show "(pending)" for it instead of a hash that's guaranteed to go stale.
python3 scripts/gen_changelog.py --pending-latest-hash 2>/dev/null

# Fold updated files into the commit silently
git add CHANGELOG.md README.md 2>/dev/null
git commit --amend --no-edit --no-verify --quiet 2>/dev/null

exit 0
